# Disable PHP and script execution in the uploads directory
<FilesMatch "\.(php|phtml|php3|php4|php5|phps|phar|sh|exe|bat|cmd|pl|py|cgi|html|htm|js)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Prevent engine execution if PHP is loaded as a module
<IfModule mod_php5.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Remove handlers
RemoveHandler .php .phtml .php3 .php4 .php5 .phar
RemoveType .php .phtml .php3 .php4 .php5 .phar

# Force HTTPS and handle client-side routing fallback for Vite React SPA and PHP REST API

RewriteEngine On

# 1. Force HTTPS (Commented out for local development; uncomment when deploying to production)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Prevent directory listings
Options -Indexes

# 3. Allow API requests to pass to directory (handled by api/.htaccess)
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^(.*)$ - [L]

# 4. Allow uploads to be served statically
RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
RewriteRule ^(.*)$ - [L]

# 5. Serve existing static files directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*)$ - [L]

# 6. Fallback everything else to React index.html for SPA routing
RewriteRule ^(.*)$ /index.html [L]
